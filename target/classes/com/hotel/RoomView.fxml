<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.RoomViewController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="20">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <VBox spacing="8" style="-fx-background-color: #1a1d2e; -fx-padding: 20; -fx-background-radius: 10; -fx-min-width: 180;">
            <HBox spacing="6">
                <Label text="🏨" style="-fx-font-size: 14px;"/>
                <Label text="Total Rooms" style="-fx-text-fill: #8892a4; -fx-font-size: 13px;"/>
            </HBox>
            <Label fx:id="totalRoomsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" style="-fx-background-color: #1a1d2e; -fx-padding: 20; -fx-background-radius: 10; -fx-min-width: 180;">
            <HBox spacing="6">
                <Label text="✅" style="-fx-font-size: 14px;"/>
                <Label text="Available Rooms" style="-fx-text-fill: #8892a4; -fx-font-size: 13px;"/>
            </HBox>
            <Label fx:id="availableRoomsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" style="-fx-background-color: #1a1d2e; -fx-padding: 20; -fx-background-radius: 10; -fx-min-width: 180;">
            <HBox spacing="6">
                <Label text="🔴" style="-fx-font-size: 14px;"/>
                <Label text="Occupied Rooms" style="-fx-text-fill: #8892a4; -fx-font-size: 13px;"/>
            </HBox>
            <Label fx:id="occupiedRoomsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <GridPane hgap="10" vgap="10">
        <padding>
            <Insets top="10" bottom="10"/>
        </padding>
        <Label text="Room Number:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="roomNumField" promptText="Room Number" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Room Type:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="typeBox" promptText="Select Type" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Price Per Day:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="priceField" promptText="Price Per Day" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Button text="Add Room" onAction="#handleAddRoom" styleClass="btn-primary" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Show All" onAction="#handleShowAll" styleClass="btn-primary"/>
        <Button text="Show Available" onAction="#handleShowAvailable" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="roomNumCol" text="Room No"/>
            <TableColumn fx:id="roomTypeCol" text="Type"/>
            <TableColumn fx:id="roomPriceCol" text="Price/Day"/>
            <TableColumn fx:id="roomStatusCol" text="Status"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <Button text="Delete Selected Room" onAction="#handleDeleteRoom" style="-fx-background-color: #dc2626;"/>

</VBox>
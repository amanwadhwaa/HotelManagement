<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30;" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.RoomViewController">

    <HBox spacing="20">
        <VBox spacing="8" style="-fx-background-color: #1a1d2e; -fx-padding: 20 25 20 25; -fx-background-radius: 10; -fx-min-width: 220; -fx-min-height: 100; -fx-border-color: transparent transparent transparent #2563eb; -fx-border-width: 0 0 0 6; -fx-border-radius: 10;">
            <Label text="Total Rooms" style="-fx-text-fill: #8892a4; -fx-font-size: 12px;"/>
            <Label fx:id="totalRoomsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" style="-fx-background-color: #1a1d2e; -fx-padding: 20 25 20 25; -fx-background-radius: 10; -fx-min-width: 220; -fx-min-height: 100; -fx-border-color: transparent transparent transparent #16a34a; -fx-border-width: 0 0 0 6; -fx-border-radius: 10;">
            <Label text="Available Rooms" style="-fx-text-fill: #8892a4; -fx-font-size: 12px;"/>
            <Label fx:id="availableRoomsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" style="-fx-background-color: #1a1d2e; -fx-padding: 20 25 20 25; -fx-background-radius: 10; -fx-min-width: 220; -fx-min-height: 100; -fx-border-color: transparent transparent transparent #dc2626; -fx-border-width: 0 0 0 6; -fx-border-radius: 10;">
            <Label text="Occupied Rooms" style="-fx-text-fill: #8892a4; -fx-font-size: 12px;"/>
            <Label fx:id="occupiedRoomsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <VBox spacing="12" style="-fx-background-color: #1a1d2e; -fx-padding: 25; -fx-background-radius: 10;">
        <Label text="Add New Room" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 0 0 15 0;"/>

        <GridPane hgap="14" vgap="12">
            <Label text="Room Number:" style="-fx-text-fill: #8892a4; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="roomNumField" minWidth="280" promptText="Room Number" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Room Type:" style="-fx-text-fill: #8892a4; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="typeBox" minWidth="280" promptText="Select Type" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Price Per Day:" style="-fx-text-fill: #8892a4; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="priceField" minWidth="280" promptText="Price Per Day" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Button text="Add Room" onAction="#handleAddRoom" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        </GridPane>
    </VBox>

    <HBox spacing="10">
        <Button text="Show All" onAction="#handleShowAll" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="Show Available" onAction="#handleShowAvailable" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="Export CSV" onAction="#handleExportCsv" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>

    <VBox spacing="12" style="-fx-background-color: #1a1d2e; -fx-background-radius: 10; -fx-padding: 5;" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_RIGHT">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Delete Selected Room" onAction="#handleDeleteRoom" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6;"/>
        </HBox>

        <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="roomNumCol" text="Room No"/>
                <TableColumn fx:id="roomTypeCol" text="Type"/>
                <TableColumn fx:id="roomPriceCol" text="Price/Day"/>
                <TableColumn fx:id="roomStatusCol" text="Status"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>
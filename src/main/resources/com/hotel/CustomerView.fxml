<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" styleClass="view-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.CustomerViewController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox spacing="12" styleClass="panel-card">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        <Label text="All registered guests appear here automatically when a booking is made." style="-fx-text-fill: #8892a4; -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
        <Button text="Delete Selected Guest" onAction="#handleDeleteCustomer" style="-fx-background-color: #dc2626;"/>
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameCol" text="Name"/>
            <TableColumn fx:id="contactCol" text="Contact"/>
            <TableColumn fx:id="roomNoCol" text="Room No"/>
        </columns>
    </TableView>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" styleClass="view-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.BillingViewController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox spacing="10" styleClass="panel-card">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        <Button text="Refresh" onAction="#handleRefresh"/>
        <Button text="Print Bill" onAction="#handlePrintBill" styleClass="success-btn"/>
        <Button text="Delete Selected Bill" onAction="#handleDeleteBill" style="-fx-background-color: #dc2626;"/>
    </HBox>

    <TableView fx:id="billingTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="bookingIdCol" text="Booking ID"/>
            <TableColumn fx:id="customerCol" text="Customer"/>
            <TableColumn fx:id="roomNoCol" text="Room No"/>
            <TableColumn fx:id="typeCol" text="Type"/>
            <TableColumn fx:id="pricePerDayCol" text="Price/Day"/>
            <TableColumn fx:id="checkInCol" text="Check-in"/>
            <TableColumn fx:id="checkOutCol" text="Check-out"/>
            <TableColumn fx:id="totalBillCol" text="Total Bill"/>
        </columns>
    </TableView>

    <Label fx:id="billSummaryLabel" text="Select a booking to see bill details" styleClass="total-banner"/>
</VBox>

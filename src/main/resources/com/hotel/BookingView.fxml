<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" styleClass="view-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.BookingViewController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <GridPane hgap="15" vgap="12" styleClass="panel-card">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Create New Booking" styleClass="section-title" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2"/>

        <Label text="Customer Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="customerNameField" promptText="Enter customer name" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Contact:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="contactField" promptText="Enter contact number" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Available Room:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="availableRoomBox" promptText="Select available room" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Check-in Date:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <DatePicker fx:id="checkInPicker" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Check-out Date:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <DatePicker fx:id="checkOutPicker" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Button text="Book Room" onAction="#handleBookRoom" styleClass="success-btn" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
    </GridPane>

    <HBox spacing="10" styleClass="panel-card">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        <Button text="Checkout Selected" onAction="#handleCheckoutSelected" styleClass="danger-btn"/>
        <Button text="Delete Selected Booking" onAction="#handleDeleteBooking" style="-fx-background-color: #dc2626;"/>
    </HBox>

    <TableView fx:id="bookingTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID"/>
            <TableColumn fx:id="customerCol" text="Customer"/>
            <TableColumn fx:id="roomNoCol" text="Room No"/>
            <TableColumn fx:id="typeCol" text="Type"/>
            <TableColumn fx:id="checkInCol" text="Check-in"/>
            <TableColumn fx:id="checkOutCol" text="Check-out"/>
            <TableColumn fx:id="activeCol" text="Active"/>
        </columns>
    </TableView>
</VBox>
